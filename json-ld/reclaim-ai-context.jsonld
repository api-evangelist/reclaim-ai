    "userTimezone": { "@id": "reclaim:userTimezone", "@type": "xsd:string" },
    "userOrgId": { "@id": "reclaim:userOrgId", "@type": "xsd:string" },

    "SchedulePolicy": "reclaim:SchedulePolicy",
